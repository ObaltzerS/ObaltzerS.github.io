---
interface Props {
  name?: string;
  tagline?: string;
  github?: string;
  email?: string;
}

const {
  name = 'Oliver Baltzer',
  tagline = 'Building things and tracking the journey — past projects, current work, and ideas still on the board.',
  github = 'https://github.com/ObaltzerS',
  email,
} = Astro.props;
---

<section class="hero section">
  <div class="container">
    <p class="eyebrow muted">Portfolio</p>
    <h1>{name}</h1>
    <p class="tagline muted">{tagline}</p>
    <div class="links">
      <a class="btn primary" href={github} target="_blank" rel="noreferrer">GitHub</a>
      {email && (
        <a class="btn" href={`mailto:${email}`}>Email</a>
      )}
      <a class="btn" href="#projects">View projects</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 5rem;
    padding-bottom: 3rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 3.4rem);
    line-height: 1.1;
    letter-spacing: -0.04em;
    font-weight: 700;
  }

  .tagline {
    margin: 1rem 0 0;
    max-width: 36rem;
    font-size: 1.125rem;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.75rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.5rem;
    padding: 0.5rem 1rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    transition: border-color 0.15s ease, background 0.15s ease;
  }

  .btn:hover {
    border-color: #d6d3d1;
    background: #f5f5f4;
  }

  .btn.primary {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }

  .btn.primary:hover {
    background: #1e40af;
    border-color: #1e40af;
  }
</style>
