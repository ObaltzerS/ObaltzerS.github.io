---
interface Props {
  bio?: string;
}

const {
  bio = "BIO PLACEHOLDER",
} = Astro.props;
---

<section id="about" class="section about">
  <div class="container">
    <h2 class="section-title">About</h2>
    <div class="card">
      <p class="muted">{bio}</p>
    </div>
  </div>
</section>

<style>
  .about {
    padding-top: 2rem;
  }

  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.5rem 1.75rem;
    max-width: 42rem;
  }

  .card p {
    margin: 0;
    font-size: 1.05rem;
  }
</style>
